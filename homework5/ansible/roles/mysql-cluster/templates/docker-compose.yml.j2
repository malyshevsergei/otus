version: '3.8'

services:
  mysql-server-1:
    image: {{ mysql_image }}
    container_name: mysql-server-1
    hostname: mysql-server-1
    environment:
      MYSQL_ROOT_PASSWORD: {{ mysql_root_password }}
      MYSQL_ROOT_HOST: '%'
    volumes:
      - mysql-server-1-data:/var/lib/mysql
      - {{ project_dir }}/config/my.cnf:/etc/my.cnf
      - {{ project_dir }}/scripts:/scripts
    networks:
      mysql-cluster:
        ipv4_address: 172.20.0.11
    ports:
      - "3311:3306"
      - "33061:33060"
    command: ["mysqld", "--server-id=1", "--log-bin=mysql-bin", "--gtid-mode=ON", "--enforce-gtid-consistency=ON", "--binlog-checksum=NONE"]
    healthcheck:
      test: ["CMD", "mysqladmin", "ping", "-h", "localhost", "-uroot", "-p{{ mysql_root_password }}"]
      interval: 10s
      timeout: 5s
      retries: 5
    restart: unless-stopped

  mysql-server-2:
    image: {{ mysql_image }}
    container_name: mysql-server-2
    hostname: mysql-server-2
    environment:
      MYSQL_ROOT_PASSWORD: {{ mysql_root_password }}
      MYSQL_ROOT_HOST: '%'
    volumes:
      - mysql-server-2-data:/var/lib/mysql
      - {{ project_dir }}/config/my.cnf:/etc/my.cnf
      - {{ project_dir }}/scripts:/scripts
    networks:
      mysql-cluster:
        ipv4_address: 172.20.0.12
    ports:
      - "3312:3306"
      - "33062:33060"
    command: ["mysqld", "--server-id=2", "--log-bin=mysql-bin", "--gtid-mode=ON", "--enforce-gtid-consistency=ON", "--binlog-checksum=NONE"]
    healthcheck:
      test: ["CMD", "mysqladmin", "ping", "-h", "localhost", "-uroot", "-p{{ mysql_root_password }}"]
      interval: 10s
      timeout: 5s
      retries: 5
    depends_on:
      mysql-server-1:
        condition: service_healthy
    restart: unless-stopped

  mysql-server-3:
    image: {{ mysql_image }}
    container_name: mysql-server-3
    hostname: mysql-server-3
    environment:
      MYSQL_ROOT_PASSWORD: {{ mysql_root_password }}
      MYSQL_ROOT_HOST: '%'
    volumes:
      - mysql-server-3-data:/var/lib/mysql
      - {{ project_dir }}/config/my.cnf:/etc/my.cnf
      - {{ project_dir }}/scripts:/scripts
    networks:
      mysql-cluster:
        ipv4_address: 172.20.0.13
    ports:
      - "3313:3306"
      - "33063:33060"
    command: ["mysqld", "--server-id=3", "--log-bin=mysql-bin", "--gtid-mode=ON", "--enforce-gtid-consistency=ON", "--binlog-checksum=NONE"]
    healthcheck:
      test: ["CMD", "mysqladmin", "ping", "-h", "localhost", "-uroot", "-p{{ mysql_root_password }}"]
      interval: 10s
      timeout: 5s
      retries: 5
    depends_on:
      mysql-server-1:
        condition: service_healthy
    restart: unless-stopped

  mysql-shell:
    image: {{ mysql_image }}
    container_name: mysql-shell
    hostname: mysql-shell
    environment:
      MYSQL_ROOT_PASSWORD: {{ mysql_root_password }}
    networks:
      mysql-cluster:
        ipv4_address: 172.20.0.10
    volumes:
      - {{ project_dir }}/scripts:/scripts
    depends_on:
      mysql-server-1:
        condition: service_healthy
      mysql-server-2:
        condition: service_healthy
      mysql-server-3:
        condition: service_healthy
    entrypoint: /bin/bash
    command: -c "tail -f /dev/null"
    restart: unless-stopped

  mysql-router:
    image: {{ mysql_router_image }}
    container_name: mysql-router
    hostname: mysql-router
    environment:
      MYSQL_HOST: mysql-server-1
      MYSQL_PORT: 3306
      MYSQL_USER: root
      MYSQL_PASSWORD: {{ mysql_root_password }}
      MYSQL_INNODB_CLUSTER_MEMBERS: 3
    networks:
      mysql-cluster:
        ipv4_address: 172.20.0.20
    ports:
      - "6446:6446"
      - "6447:6447"
    depends_on:
      mysql-server-1:
        condition: service_healthy
      mysql-server-2:
        condition: service_healthy
      mysql-server-3:
        condition: service_healthy
    restart: unless-stopped

networks:
  mysql-cluster:
    driver: bridge
    ipam:
      config:
        - subnet: {{ mysql_cluster_subnet }}

volumes:
  mysql-server-1-data:
  mysql-server-2-data:
  mysql-server-3-data:
