server {
    listen 80 default_server;
    server_name _;

    root /var/www/html;
    index index.html;

    # Health check endpoint for Consul — returns 200 OK with no logging
    location /health {
        access_log off;
        return 200 "OK\n";
        add_header Content-Type text/plain;
    }

    location / {
        try_files $uri $uri/ =404;
    }

    access_log /var/log/nginx/webapp_access.log;
    error_log  /var/log/nginx/webapp_error.log;
}
