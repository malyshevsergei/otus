datacenter  = "{{ consul_datacenter }}"
domain      = "{{ consul_domain }}"
data_dir    = "/opt/consul"
log_level   = "INFO"
node_name   = "{{ inventory_hostname }}"
bind_addr   = "{{ consul_bind_addr }}"
client_addr = "0.0.0.0"
encrypt     = "{{ consul_encrypt_key }}"

retry_join = {{ consul_server_ips | tojson }}

{% if consul_mode == 'server' %}
server           = true
bootstrap_expect = {{ consul_server_ips | length }}

ui_config {
  enabled = true
}
{% else %}
server = false
{% endif %}

ports {
  dns = 8600
}

# Enables script checks (used for custom health checks if needed)
enable_script_checks = false
enable_local_script_checks = true
